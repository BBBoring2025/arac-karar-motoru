# ============================================
# Araç Karar Motoru - Environment Variables
# ============================================
# Bu dosyayı kopyalayın: cp .env.local.example .env.local
# Ardından gerçek değerleri girin.

# ------------------------------------------
# Supabase
# ------------------------------------------
# Supabase proje URL'i (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings > API > anon public)
# Client tarafında kullanılır, RLS ile korunur
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings > API > service_role secret)
# SADECE sunucu tarafında kullanılır — bu anahtarı ASLA client'a expose etmeyin!
# RLS'yi bypass eder, admin işlemleri için gereklidir
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------
# Site
# ------------------------------------------
# Canonical URL — SEO metadata, sitemap ve OG etiketleri için kullanılır
# Vercel'de: Settings > Environment Variables > NEXT_PUBLIC_SITE_URL
NEXT_PUBLIC_SITE_URL=https://arackararmotoru.com
