# ============================================
# Araç Karar Motoru - Environment Variables
# ============================================
# Kopyala: cp .env.local.example .env.local
# Ardından gerçek değerleri gir.

# ------------------------------------------
# Supabase (ZORUNLU)
# ------------------------------------------
# Supabase proje URL'i (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings > API > anon public)
# Client tarafında kullanılır, RLS ile korunur
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings > API > service_role secret)
# ⚠️ SADECE sunucu tarafında! Bu anahtarı ASLA client'a expose etme!
# RLS'yi bypass eder, admin işlemleri için gereklidir
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------
# Site (ZORUNLU)
# ------------------------------------------
# Canonical URL — SEO, sitemap, OG etiketleri ve ödeme callback için
NEXT_PUBLIC_SITE_URL=https://arackararmotoru.com

# ------------------------------------------
# iyzico Ödeme (ZORUNLU — ödeme aktif olacaksa)
# ------------------------------------------
# Sandbox: https://sandbox-merchant.iyzipay.com hesabından al
# Production: https://merchant.iyzipay.com hesabından al
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key

# Sandbox URL (test ortamı):
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Production URL (canlı):
# IYZICO_BASE_URL=https://api.iyzipay.com

# ------------------------------------------
# Admin (OPSİYONEL)
# ------------------------------------------
# Admin kullanıcı: Supabase Auth'da kayıtlı + kullanicilar tablosunda rol='admin'
# ADMIN_EMAIL=admin@arackararmotoru.com

# ------------------------------------------
# Analytics (OPSİYONEL)
# ------------------------------------------
# Google Analytics 4
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-id

# ------------------------------------------
# ENV AYRIMI:
# ------------------------------------------
# NEXT_PUBLIC_* → Client + Server (tarayıcıda görünür, gizli bilgi KOYMA)
# Diğerleri     → Sadece Server (API routes, middleware)
#
# ⚠️ SUPABASE_SERVICE_ROLE_KEY → Sadece server
# ⚠️ IYZICO_API_KEY/SECRET_KEY → Sadece server
# ✅ NEXT_PUBLIC_SUPABASE_URL  → Client OK (RLS korumalı)
# ✅ NEXT_PUBLIC_SITE_URL      → Client OK (public bilgi)
