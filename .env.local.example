# ============================================
# Arac Karar Motoru - Environment Variables
# ============================================
# Bu dosyayi kopyalayin: cp .env.local.example .env.local
# Ardindan gercek degerleri girin.

# ------------------------------------------
# Supabase (Zorunlu)
# ------------------------------------------
# Supabase proje URL'i (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings > API > anon public)
# Client tarafinda kullanilir, RLS ile korunur
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings > API > service_role secret)
# SADECE sunucu tarafinda kullanilir — bu anahtari ASLA client'a expose etmeyin!
# RLS'yi bypass eder, admin islemleri icin gereklidir
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------
# Site (Zorunlu)
# ------------------------------------------
# Canonical URL — SEO metadata, sitemap ve OG etiketleri icin kullanilir
# Vercel'de: Settings > Environment Variables > NEXT_PUBLIC_SITE_URL
NEXT_PUBLIC_SITE_URL=https://arackararmotoru.com

# ------------------------------------------
# iyzico Odeme Sistemi (Gelecek - Henuz aktif degil)
# ------------------------------------------
# iyzico entegrasyonu tamamlandiginda bu anahtarlar gerekecek
# iyzico sandbox: https://sandbox-merchant.iyzipay.com
# iyzico production: https://merchant.iyzipay.com
# IYZICO_API_KEY=your-iyzico-api-key
# IYZICO_SECRET_KEY=your-iyzico-secret-key
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ------------------------------------------
# Admin (Opsiyonel)
# ------------------------------------------
# Admin paneli icin yetkilendirme. Supabase Auth ile calisir.
# Admin kullanici email'i (Supabase Auth'da kayitli olmali)
# ADMIN_EMAIL=admin@arackararmotoru.com

# ------------------------------------------
# Analytics (Opsiyonel - Gelecek)
# ------------------------------------------
# Google Analytics veya Vercel Analytics tracking ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-analytics-id
